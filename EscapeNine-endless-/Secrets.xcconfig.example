// Secrets.xcconfig.example - このファイルをコピーして Secrets.xcconfig を作成してください。
// cp Secrets.xcconfig.example Secrets.xcconfig

FACEBOOK_APP_ID = YOUR_FACEBOOK_APP_ID
FACEBOOK_CLIENT_TOKEN = YOUR_FACEBOOK_CLIENT_TOKEN
FACEBOOK_DISPLAY_NAME = Escape Nine: Endless
FACEBOOK_URL_SCHEME = fbYOUR_FACEBOOK_APP_ID

// PostHog Project API key（クライアント公開キー）。PostHog → Project Settings から取得。
POSTHOG_API_KEY = YOUR_POSTHOG_PROJECT_API_KEY
