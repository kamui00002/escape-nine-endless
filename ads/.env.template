# Meta Ads CLI 認証設定
# cp ads/.env.template ads/.env

META_ACCESS_TOKEN=your_access_token_here

# ⚠️ META_AD_ACCOUNT_ID は「act_ プレフィックスを含めない、生の数値 ID」を設定すること。
# CLI 側 (meta-ads CLI) が API 呼び出し時に自動で `act_` を付与するため、
# ここに `act_` を含めると `act_act_123456...` の二重プレフィックスになり、
# キャンペーン作成 API が失敗するか、間違ったアカウントに作成しに行く。
# 例: META_AD_ACCOUNT_ID=153606124398210  (正)
#     META_AD_ACCOUNT_ID=act_153606124398210  (NG 禁止)
META_AD_ACCOUNT_ID=your_account_id_here

META_PAGE_ID=your_page_id_here
